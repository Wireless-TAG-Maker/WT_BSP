# ESP32-P4 ESP-Hosted Master 配置

# 分区表配置 - 使用自定义 2MB app 分区以容纳 esp-wifi-connect 组件
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# 系统事件任务栈大小 - esp-wifi-connect 需要更大的栈
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=8192

# 注意：SDIO GPIO 配置需要在 menuconfig 中设置
# Component config -> ESP-Hosted config -> SDIO Configuration
# 请手动设置:
#   CLK GPIO = 18
#   CMD GPIO = 19
#   D0 GPIO = 14
#   D1 GPIO = 15
#   D2 GPIO = 16
#   D3 GPIO = 17
#   Slave Reset GPIO = 13

# Wi-Fi 配置
CONFIG_ESP_MAXIMUM_RETRY=5
CONFIG_ESP_WIFI_SSID="CMW-AP2025"
CONFIG_ESP_WIFI_PASSWORD="12345678"

# LWIP 配置优化
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=65534
CONFIG_LWIP_TCP_WND_DEFAULT=65534
CONFIG_LWIP_TCP_RECVMBOX_SIZE=64
CONFIG_LWIP_UDP_RECVMBOX_SIZE=64
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=64
CONFIG_LWIP_TCP_SACK_OUT=y

# Wi-Fi 缓冲区配置
CONFIG_WIFI_RMT_STATIC_RX_BUFFER_NUM=16
CONFIG_WIFI_RMT_DYNAMIC_RX_BUFFER_NUM=64
CONFIG_WIFI_RMT_DYNAMIC_TX_BUFFER_NUM=64
CONFIG_WIFI_RMT_AMPDU_TX_ENABLED=y
CONFIG_WIFI_RMT_TX_BA_WIN=32
CONFIG_WIFI_RMT_AMPDU_RX_ENABLED=y
CONFIG_WIFI_RMT_RX_BA_WIN=32

# ESP-Hosted SDIO GPIO 配置
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=19
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=18
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=14
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=15
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=16
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=17
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=13
CONFIG_SLAVE_IDF_TARGET_ESP32C61=y

# WT-BSP 配置
CONFIG_WT_BSP=y
CONFIG_WT_BSP_BOARD_WT9932P4C61_TINY=y

CONFIG_BOOTLOADER_LOG_LEVEL_WARN=y
CONFIG_BOOTLOADER_LOG_LEVEL=2
